{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      "git pull *": "ask",
      "git checkout *": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "rm *": "deny",
